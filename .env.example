# Scrappy Admin Console — API
#
# Live Scrappy API (see API reference §20 Admin supervision):
#   Base: http://localhost:3000/api/v1
#   Auth: POST /admin/auth/login  (SUPER_ADMIN only; body: { identifier, password })
#   Refresh/logout: POST /auth/refresh, POST /auth/logout
#   Me: GET /users/me
#   Companies: /admin/companies, /admin/companies/{id}/accounts
#   Subscriptions: /admin/companies/{companyId}/subscriptions*
#   Analytics: /admin/analytics/overview (+ per-company analytics)
#
# When VITE_USE_MOCK=true, local handlers simulate these admin contracts.
# Features without a live admin endpoint (platform settings, exports hub,
# global search, administrator CRUD) remain mock-only.

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_USE_MOCK=true

# Remember Me: access token in memory; refresh in localStorage (Remember Me)
# or sessionStorage (session-only).
